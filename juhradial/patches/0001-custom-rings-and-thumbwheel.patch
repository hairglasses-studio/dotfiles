+fn default_launcher_menu_name() -> String { "launcher".to_string() }
+fn default_clipboard_menu_name() -> String { "clipboard".to_string() }
+
+/// Which named radial menu each MX thumb/gesture trigger should open.
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct RadialMenuAssignmentsConfig {
+    #[serde(default = "default_clipboard_menu_name")]
+    pub gesture: String,
+
+    #[serde(default = "default_launcher_menu_name")]
+    pub thumb: String,
+}
+
+impl Default for RadialMenuAssignmentsConfig {
+    fn default() -> Self {
+        Self {
+            gesture: default_clipboard_menu_name(),
+            thumb: default_launcher_menu_name(),
+        }
+    }
+}
+
+fn default_thumbwheel_mode() -> String { "kitty_font_size".to_string() }
+fn default_thumbwheel_targets() -> Vec<String> { vec!["kitty".to_string()] }
+fn default_thumbwheel_step() -> f64 { 0.5 }
+fn default_thumbwheel_min_font_size() -> f64 { 6.0 }
+fn default_thumbwheel_max_font_size() -> f64 { 12.0 }
+
+/// Horizontal thumb-wheel policy.
+#[derive(Debug, Clone, Serialize, Deserialize)]
+pub struct ThumbwheelConfig {
+    #[serde(default = "default_thumbwheel_mode")]
+    pub mode: String,
+
+    #[serde(default = "default_thumbwheel_targets")]
+    pub target_window_classes: Vec<String>,
+
+    #[serde(default = "default_thumbwheel_step")]
+    pub step: f64,
+
+    #[serde(default = "default_thumbwheel_min_font_size")]
+    pub min_font_size: f64,
+
+    #[serde(default = "default_thumbwheel_max_font_size")]
+    pub max_font_size: f64,
+
+    #[serde(default = "default_true")]
+    pub pass_through_unmatched: bool,
+}
+
+impl Default for ThumbwheelConfig {
+    fn default() -> Self {
+        Self {
+            mode: default_thumbwheel_mode(),
+            target_window_classes: default_thumbwheel_targets(),
+            step: default_thumbwheel_step(),
+            min_font_size: default_thumbwheel_min_font_size(),
+            max_font_size: default_thumbwheel_max_font_size(),
+            pass_through_unmatched: true,
+        }
+    }
+}
+
+impl ThumbwheelConfig {
+    pub fn kitty_font_size_mode(&self) -> bool {
+        self.mode == "kitty_font_size"
+    }
+}
