#!/bin/bash
# SketchyBar — Snazzy-on-black menu bar
# https://felixkratz.github.io/SketchyBar/

PLUGIN_DIR="$CONFIG_DIR/plugins"

# ── Palette ──────────────────────────────────────
BLUE=0xff57c7ff
MAGENTA=0xffff6ac1
GREEN=0xff5af78e
YELLOW=0xfff3f99d
RED=0xffff5c57
GRAY=0xff686868
DARK=0xff1a1a1a
BRIGHT=0xfff1f1f0
FG=0xffd4d4d4
BG=0xe61a1a1a
TRANSPARENT=0x00000000

# ── Bar ──────────────────────────────────────────
sketchybar --bar \
    height=40 \
    blur_radius=30 \
    position=top \
    sticky=on \
    padding_left=8 \
    padding_right=8 \
    color=$BG \
    shadow=on

# ── Defaults ─────────────────────────────────────
sketchybar --default \
    icon.font="JetBrainsMono Nerd Font:Bold:14.0" \
    icon.color=$BLUE \
    label.font="JetBrainsMono Nerd Font:Medium:13.0" \
    label.color=$FG \
    padding_left=4 \
    padding_right=4 \
    background.color=$TRANSPARENT \
    background.corner_radius=6 \
    background.height=28

# ── Workspaces (AeroSpace integration) ───────────
for sid in $(seq 1 9); do
    sketchybar --add item space.$sid left \
        --set space.$sid \
            associated_space=$sid \
            icon=$sid \
            icon.font="JetBrainsMono Nerd Font:Bold:13.0" \
            icon.color=$GRAY \
            icon.highlight_color=0xff000000 \
            label.drawing=off \
            background.color=$TRANSPARENT \
            background.drawing=on \
            padding_left=2 \
            padding_right=2 \
            click_script="aerospace workspace $sid" \
            script="$PLUGIN_DIR/space.sh"
done

sketchybar --add event aerospace_workspace_change

for sid in $(seq 1 9); do
    sketchybar --subscribe space.$sid aerospace_workspace_change
done

# ── Front App ────────────────────────────────────
sketchybar --add item front_app left \
    --set front_app \
        icon.drawing=off \
        label.font="JetBrainsMono Nerd Font:Bold:13.0" \
        label.color=$MAGENTA \
        padding_left=8 \
        script="$PLUGIN_DIR/front_app.sh" \
    --subscribe front_app front_app_switched

# ── Right side (ordered right-to-left) ───────────

# Clock
sketchybar --add item clock right \
    --set clock \
        icon= \
        icon.color=$MAGENTA \
        label.color=$FG \
        update_freq=30 \
        script="$PLUGIN_DIR/clock.sh"

# Battery
sketchybar --add item battery right \
    --set battery \
        update_freq=120 \
        script="$PLUGIN_DIR/battery.sh" \
    --subscribe battery system_woke power_source_change

# CPU
sketchybar --add item cpu right \
    --set cpu \
        icon=󰘚 \
        icon.color=$GRAY \
        label.color=$GRAY \
        update_freq=5 \
        script="$PLUGIN_DIR/cpu.sh"

# Wi-Fi
sketchybar --add item wifi right \
    --set wifi \
        icon=󰖩 \
        icon.color=$GRAY \
        label.color=$GRAY \
        script="$PLUGIN_DIR/wifi.sh" \
    --subscribe wifi wifi_change

# K8s context
sketchybar --add item k8s right \
    --set k8s \
        icon=󱃾 \
        icon.color=$BLUE \
        label.color=$BLUE \
        update_freq=30 \
        script="$PLUGIN_DIR/k8s_context.sh"

# ── Finalize ─────────────────────────────────────
sketchybar --update
