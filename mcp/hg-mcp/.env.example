# hg-mcp Environment Variables
# Copy this file to .env and fill in your actual values

# ── Core MCP ─────────────────────────────────────────────
# MCP_MODE=stdio              # Options: stdio, sse, web
# PORT=8080                   # Only used if MCP_MODE=sse or web
# AFTRS_VAULT_PATH=$HOME/Documents/aftrs-vault
# AFTRS_DATA_DIR=~/.hg-mcp
# AFTRS_USER=

# ── Security ─────────────────────────────────────────────
# RBAC_USERS=mitch:admin,luke:operator,default:readonly

# ── Observability ────────────────────────────────────────
DISABLE_TRACING=
DISABLE_METRICS=
# GRAFANA_ADMIN_PASSWORD=changeme

# ── Discord ──────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=
# DISCORD_WEBHOOK_URL=
# DISCORD_STREAM_ALERTS_CHANNEL=
# DISCORD_TECH_ALERTS_CHANNEL=
# DISCORD_SESSION_LOG_CHANNEL=

# ── Google (Gmail / Calendar / Drive / Tasks) ────────────
# Option A: Service account credentials file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
# Option B: API key
# GOOGLE_API_KEY=
# Option C: OAuth (for Gmail - run cmd/gmail-auth first)
# GMAIL_APPLICATION_CREDENTIALS=/path/to/gmail-credentials.json
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Spotify ──────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── SoundCloud ───────────────────────────────────────────
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=

# ── Beatport ─────────────────────────────────────────────
BEATPORT_USERNAME=
BEATPORT_PASSWORD=
# BEATPORT_ACCESS_TOKEN=
# BEATPORT_REFRESH_TOKEN=

# ── Tidal ────────────────────────────────────────────────
# TIDAL_CLIENT_ID=
# TIDAL_CLIENT_SECRET=
# TIDAL_COUNTRY_CODE=US

# ── Discogs ──────────────────────────────────────────────
# DISCOGS_TOKEN=

# ── Notion ───────────────────────────────────────────────
NOTION_API_KEY=
# NOTION_TOKEN=                     # Alias for NOTION_API_KEY
# HG_PAGES_DATABASE_ID=

# ── Twitch ───────────────────────────────────────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BROADCASTER_ID=
# TWITCH_CHANNEL_ID=                # Alias for TWITCH_BROADCASTER_ID

# ── YouTube ──────────────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
# YOUTUBE_MUSIC_HEADERS_PATH=

# ── Home Assistant ───────────────────────────────────────
HASS_URL=
HASS_TOKEN=

# ── MQTT ─────────────────────────────────────────────────
MQTT_BROKER=
# MQTT_CLIENT_ID=hg-mcp
# MQTT_USERNAME=
# MQTT_PASSWORD=

# ── Resolume ─────────────────────────────────────────────
# RESOLUME_OSC_HOST=127.0.0.1
# RESOLUME_OSC_PORT=7000
# RESOLUME_API_PORT=8080
# RESOLUME_EFFECTS_PATH=
# RESOLUME_SOURCES_PATH=
# RESOLUME_PLUGINS_BUCKET=

# ── TouchDesigner ────────────────────────────────────────
# TD_HOST=127.0.0.1
# TD_PORT=9980
# TD_PALETTE_PATH=
# TD_COMPONENTS_PATH=

# ── Ableton / Max for Live ───────────────────────────────
# ABLETON_OSC_HOST=127.0.0.1
# ABLETON_OSC_PORT=11000
# ABLETON_OSC_REPLY_PORT=11001
# M4L_OSC_HOST=127.0.0.1
# M4L_OSC_PORT=9000
# M4L_OSC_REPLY_PORT=9001

# ── OBS ──────────────────────────────────────────────────
# OBS_HOST=localhost:4455

# ── grandMA3 ─────────────────────────────────────────────
# GRANDMA3_HOST=
# GRANDMA3_OSC_PORT=8000

# ── ATEM ─────────────────────────────────────────────────
# ATEM_HOST=
# ATEM_PORT=9910

# ── ShowKontrol ──────────────────────────────────────────
# SHOWKONTROL_HOST=
# SHOWKONTROL_PORT=8000
# SHOWKONTROL_API_KEY=

# ── PTZ Cameras ──────────────────────────────────────────
# PTZ_HOST=
# PTZ_PORT=80
# PTZ_USERNAME=admin
# PTZ_PASSWORD=
# PTZ_CAMERAS=                      # JSON array of camera configs

# ── Lighting / Art-Net ───────────────────────────────────
# ARTNET_HOST=
# LIGHTING_CONFIG=

# ── LedFX ────────────────────────────────────────────────
# LEDFX_HOST=127.0.0.1
# LEDFX_PORT=8888

# ── MIDI ─────────────────────────────────────────────────
# MIDI_OUTPUT=
# MIDI_INPUT=

# ── Dante ────────────────────────────────────────────────
# DANTE_INTERFACE=

# ── Unraid ───────────────────────────────────────────────
UNRAID_HOST=
UNRAID_API_KEY=

# ── OPNsense ─────────────────────────────────────────────
# OPNSENSE_HOST=
# OPNSENSE_API_KEY=
# OPNSENSE_API_SECRET=

# ── Tailscale ────────────────────────────────────────────
# (Uses tailscale CLI — no env vars needed)

# ── Inventory (Google Sheets backend) ─────────────────────
# Auth: run "gcloud auth application-default login --scopes=https://www.googleapis.com/auth/spreadsheets"
INVENTORY_SPREADSHEET_ID=
# INVENTORY_PHOTOS_DRIVE_FOLDER_ID=   # Google Drive folder ID for product photos (phone auto-upload)
# INVENTORY_BUCKET_NAME=              # (legacy DynamoDB/S3 — unused)
# INVENTORY_TABLE_NAME=               # (legacy DynamoDB/S3 — unused)

# ── AWS / CR8 ────────────────────────────────────────────
# AWS_PROFILE=
# AWS_REGION=us-east-1
# CR8_S3_BUCKET=
# CR8_SCRIPTS_PATH=

# ── Rekordbox ────────────────────────────────────────────
# REKORDBOX_DB_PATH=
# REKORDBOX_MUSIC_PATH=
# REKORDBOX_PLAYLIST_PATH=
# REKORDBOX_PATH=                   # Rekordbox application path

# ── Traktor ──────────────────────────────────────────────
# TRAKTOR_COLLECTION_PATH=

# ── Serato ───────────────────────────────────────────────
# SERATO_LIBRARY_PATH=

# ── Stems / Demucs ───────────────────────────────────────
# DEMUCS_PATH=
# DEMUCS_MODEL=htdemucs
# DEMUCS_USE_GPU=true
# STEMS_OUTPUT_DIR=

# ── Whisper ──────────────────────────────────────────────
# OPENAI_API_KEY=                   # For Whisper API mode
# WHISPER_PATH=                     # For local whisper
# WHISPER_MODE=local                # local or api
# WHISPER_MODEL=base

# ── Ollama ───────────────────────────────────────────────
# OLLAMA_HOST=127.0.0.1
# OLLAMA_PORT=11434

# ── Video AI ─────────────────────────────────────────────
# VIDTOOL_PATH=
# VIDTOOL_OUTPUT_DIR=~/Videos/processed
# VIDTOOL_DEVICE=cuda
# HF_MODEL_PATH=~/.cache/huggingface

# ── FFGL ─────────────────────────────────────────────────
# FFGL_TEMPLATES_DIR=
# FFGL_OUTPUT_DIR=
# FFGL_BUILD_DIR=

# ── Audio Fingerprinting ─────────────────────────────────
# ACOUSTID_API_KEY=
# FPCALC_PATH=

# ── Retrogaming ──────────────────────────────────────────
# PCSX2_PATH=
# RETROARCH_PATH=
# PS2_GAMES_PATH=~/Games/PS2
# ROMS_PATH=
# PCSX2_CHEATS_PATH=
# ROMS_GDRIVE_PATH=

# ── Backup ───────────────────────────────────────────────
# BACKUP_CONFIG_PATH=
# BACKUP_ROOT=

# ── Rclone ───────────────────────────────────────────────
# RCLONE_CONFIG=
# RCLONE_TRANSFERS=4
# RCLONE_CHECKERS=8
# RCLONE_BANDWIDTH=
# RCLONE_DRIVE_CHUNK_SIZE=

# ── VJ Clips ────────────────────────────────────────────
# VJ_CLIPS_BUCKET=
# VJ_CLIPS_PATH=

# ── Plugins ──────────────────────────────────────────────
# GITHUB_TOKEN=
# PLUGIN_MANIFEST_PATH=
# PLUGIN_MANIFEST_URL=

# ── eBay (Inventory) ────────────────────────────────────
# EBAY_APP_ID=
# EBAY_DEV_ID=
# EBAY_CERT_ID=
# EBAY_SANDBOX_APP_ID=
# EBAY_OAUTH_REFRESH_TOKEN=
# EBAY_ENVIRONMENT=production
# EBAY_USE_SANDBOX=false

# ── AI / Anthropic ───────────────────────────────────────

# ── Private Module Access ────────────────────────────────
# MCPKIT_TOKEN=                                   # GitHub PAT for hairglasses-studio/mcpkit

# ── Misc / Session ───────────────────────────────────────
# OBSIDIAN_VAULT_PATH=~/Documents/obsidian-vault
# PYTHON_PATH=
# DJ_CRATES_PATH=
# DJ_CRATES_GDRIVE_PATH=
# NESTDROP_PATH=
# NESTDROP_GDRIVE_PATH=
# SPLICE_SAMPLES_BUCKET=
# SPLICE_PATH=
# SPLICE_GDRIVE_PATH=

# ── Hardware Monitor Thresholds ──────────────────────────
# CPU_TEMP_WARNING=80
# CPU_TEMP_CRITICAL=95
# GPU_TEMP_WARNING=85
# GPU_TEMP_CRITICAL=100

# ── 1Password ────────────────────────────────────────────
# OP_ACCOUNT=
# OP_VAULT=
# OP_SERVICE_ACCOUNT_TOKEN=
