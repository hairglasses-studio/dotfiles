# Discord Bot Configuration
# Copy this file to .env or export these variables in your shell

# Required: Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your-bot-token-here

# Required: Discord Guild/Server ID
DISCORD_GUILD_ID=your-server-id-here

# Required: Default channel for messages
DISCORD_CHANNEL_ID=your-channel-id-here

# Optional: Notification channel IDs (falls back to DISCORD_CHANNEL_ID if not set)
DISCORD_STREAM_ALERTS_CHANNEL=
DISCORD_TECH_ALERTS_CHANNEL=
DISCORD_SESSION_LOG_CHANNEL=

# Optional: Webhook URL for external notifications
DISCORD_WEBHOOK_URL=

# Optional: Vault path (defaults to ~/aftrs-vault)
AFTRS_VAULT_PATH=
