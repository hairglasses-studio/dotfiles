#
# This file is parsed by pam_env module
#
# Syntax: simple "KEY=VAL" pairs on separate lines
#
XDG_SESSION_TYPE=wayland
XDG_CURRENT_DESKTOP=Hyprland
# avoid iterating over all libseat backends
LIBSEAT_BACKEND=logind

# NVIDIA libGL selection; leave GBM_BACKEND unset so Hyprland/Aquamarine
# chooses the correct backend. Forcing nvidia-drm login-time was part of the
# 2026-04-16 planePitch regression chain — see .claude/rules/nvidia-wayland.md.
__GLX_VENDOR_LIBRARY_NAME=nvidia

# Wayland hints for toolkits
SDL_VIDEODRIVER=wayland
CLUTTER_BACKEND=wayland

# WLR_NO_HARDWARE_CURSORS is deprecated; Hyprland owns the setting via
# cursor { no_hardware_cursors = … } in hyprland.conf. Do not re-export here.
