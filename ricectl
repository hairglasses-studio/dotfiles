#!/usr/bin/env bash
# ricectl: bootstrap and manage your riced terminal environment

set -euo pipefail

# === ENV CONFIG ===
export DOTFILES_DIR="$HOME/.dotfiles"
export RICECTL_HOME="$DOTFILES_DIR/ricectl"
export ZELLIJ_LAYOUT_DIR="$DOTFILES_DIR/zellij/layouts"
export HELIX_CONFIG_DIR="$DOTFILES_DIR/helix"
export WEZTERM_CONFIG_FILE="$DOTFILES_DIR/wezterm/wezterm.lua"
export ZELLIJ_PLUGIN_MANIFEST="$HOME/.config/zellij/plugins.kdl"

# === GIT BOOTSTRAP ===
mkdir -p "$DOTFILES_DIR"
git clone https://github.com/aftrs-shell/dotfiles "$DOTFILES_DIR" || echo "dotfiles already cloned"
cd "$DOTFILES_DIR"

# === CORE TOOLS ===
declare -a CORE_TOOLS=(
  zellij
  wezterm
  helix
  starship
  zoxide
  atuin
  yazi
  broot
  btop
)

for tool in "${CORE_TOOLS[@]}"; do
  echo "Installing $tool..."
  case $tool in
    zellij)
      cargo install --locked zellij
      ;;
    wezterm)
      echo "WezTerm requires manual install: https://wezfurlong.org/wezterm/install.html"
      ;;
    helix)
      cargo install --locked helix
      ;;
    starship)
      curl -sS https://starship.rs/install.sh | sh -s -- -y
      ;;
    zoxide)
      cargo install --locked zoxide
      ;;
    atuin)
      cargo install --locked atuin
      ;;
    yazi)
      cargo install --locked yazi-fm
      ;;
    broot)
      cargo install --locked broot
      ;;
    btop)
      sudo apt install btop -y
      ;;
  esac
  echo "$tool installed."
done

# === STARSHIP CONFIG ===
mkdir -p "$HOME/.config"
cat > "$HOME/.config/starship.toml" <<EOF
add_newline = false
format = "[\uE0B6](bg:#282c34 fg:#61afef)$username$hostname[\uE0B0](bg:#61afef fg:#282c34)$directory$git_branch$git_status$cmd_duration$line_break$character"
[character]
success_symbol = "[\u276f](bold green)"
error_symbol = "[\u276f](bold red)"
[cmd_duration]
min_time = 100
style = "yellow"
[git_branch]
style = "purple"
EOF

# === ZELLIJ LAYOUTS ===
mkdir -p "$ZELLIJ_LAYOUT_DIR"
cat > "$ZELLIJ_LAYOUT_DIR/dev.kdl" <<EOF
layout {
  pane size=1 borderless=true {
    plugin location="zellij:tab-bar"
  }
  children direction="horizontal" {
    pane command="helix"
    pane command="yazi"
  }
}
EOF

# === ZELLIJ PLUGIN MANIFEST ===
mkdir -p "$(dirname $ZELLIJ_PLUGIN_MANIFEST)"
cat > "$ZELLIJ_PLUGIN_MANIFEST" <<EOF
plugins {
  plugin "zjstatus" {
    location = "https://github.com/zellij-org/zjstatus"
  }
  plugin "tab-bar" {
    location = "zellij:tab-bar"
  }
  plugin "room" {
    location = "https://github.com/imsnif/room"
  }
  plugin "monocle" {
    location = "https://github.com/imsnif/monocle"
  }
  plugin "zellij-forgot" {
    location = "https://github.com/imsnif/zellij-forgot"
  }
  plugin "zj-choose-tree" {
    location = "https://github.com/imsnif/zj-choose-tree"
  }
  plugin "zj-docker" {
    location = "https://github.com/imsnif/zj-docker"
  }
  plugin "theylix" {
    location = "https://github.com/qjolyz/theylix"
  }
  plugin "yazelix" {
    location = "https://github.com/kylecordes/yazelix"
  }
}
EOF

# === HELIX CONFIG ===
mkdir -p "$HELIX_CONFIG_DIR"
cat > "$HELIX_CONFIG_DIR/config.toml" <<EOF
theme = "tokyonight"
[editor]
line-number = "relative"
true-color = true
auto-pairs = true
[editor.cursor-shape]
insert = "bar"
normal = "block"
select = "underline"
EOF

# === WEZTERM CONFIG ===
mkdir -p "$(dirname $WEZTERM_CONFIG_FILE)"
cat > "$WEZTERM_CONFIG_FILE" <<EOF
local wezterm = require 'wezterm'
return {
  font = wezterm.font_with_fallback {
    "JetBrainsMono Nerd Font",
    "FiraCode Nerd Font",
  },
  color_scheme = "Tokyo Night",
  enable_tab_bar = true,
  use_fancy_tab_bar = false,
  hide_tab_bar_if_only_one_tab = true,
  window_decorations = "RESIZE",
  window_background_opacity = 0.90,
  scrollback_lines = 5000,
  enable_scroll_bar = false,
}
EOF

# === SHELL INIT (ZSH + Starship + Zoxide + Atuin) ===
echo 'eval "$(starship init zsh)"' >> ~/.zshrc
echo 'eval "$(zoxide init zsh)"' >> ~/.zshrc
echo 'eval "$(atuin init zsh)"' >> ~/.zshrc
echo 'alias zz="zellij --layout dev"' >> ~/.zshrc

echo "✅ Riced terminal environment installed. Run 'zellij --layout dev' to start your session."
