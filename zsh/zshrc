# ── Long-running command notification ────────
_cmd_timer_preexec() {
  _CMD_START_TIME=$EPOCHSECONDS
  _CMD_NAME="$1"
}

_cmd_timer_precmd() {
  local last_status=$?
  if [[ -n "$_CMD_START_TIME" ]]; then
    local elapsed=$(( EPOCHSECONDS - _CMD_START_TIME ))
    if (( elapsed > 30 )) && [[ -t 1 ]]; then
      # Notification sound (Linux - notify-send)
      if command -v notify-send &>/dev/null; then
        notify-send -u normal -a "Command Complete" "Command Complete" \
          "${_CMD_NAME} finished (${elapsed}s)" 2>/dev/null
      fi
    fi
    unset _CMD_START_TIME _CMD_NAME
  fi
}

autoload -Uz add-zsh-hook
add-zsh-hook preexec _cmd_timer_preexec
add-zsh-hook precmd _cmd_timer_precmd

