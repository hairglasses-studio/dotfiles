# ── Safe eval (timeout protection for shell startup) ──
_safe_eval() {
  local secs=$1; shift
  local output
  output=$(timeout "$secs" "$@" 2>/dev/null) && eval "$output" || {
    printf '\e[38;5;243m[zshrc] timed out: %s\e[0m\n' "$*" >&2
  }
}

