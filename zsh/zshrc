# ── Lazy-loaded dev tool completions ──────────────
# These plugins are loaded on first invocation to avoid
# unconditional completion init overhead.
_lazy_omz_plugin() {
  local plugin=$1; shift
  for cmd in "$@"; do
    eval "${cmd}() { unset -f $* 2>/dev/null; source \"\$ZSH/plugins/${plugin}/${plugin}.plugin.zsh\" 2>/dev/null; ${cmd} \"\\\$@\"; }"
  done
}
_lazy_omz_plugin kubectl kubectl
_lazy_omz_plugin helm helm
_lazy_omz_plugin terraform terraform
_lazy_omz_plugin aws aws
_lazy_omz_plugin docker-compose docker-compose
