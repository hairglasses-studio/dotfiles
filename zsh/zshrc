# ── Cached eval (24h cache for shell init scripts) ──
_cached_eval() {
  local name=$1; shift
  local cache="${XDG_CACHE_HOME:-$HOME/.cache}/zsh-eval-cache/${name}.zsh"
  if [[ ! -f "$cache" ]] || [[ -n "$(find "$cache" -mmin +1440 2>/dev/null)" ]]; then
    mkdir -p "${cache%/*}"
    timeout 3 "$@" > "$cache" 2>/dev/null || {
      printf '\e[38;5;243m[zshrc] cache gen failed: %s\e[0m\n' "$*" >&2
      return 1
    }
  fi
  source "$cache" 2>/dev/null
}

