# ── Managed agent launchers ────────────────────
_hg_agent_session_quiet() {
  [[ "${HG_AGENT_SESSION_QUIET:-0}" == "1" ]]
}

_hg_define_agent_wrappers() {
  unalias claude gemini codex 2>/dev/null

  claude() {
    env -u ANTHROPIC_API_KEY \
      -u PERSONAL_CLAUDE_MAX_ANTHROPIC_API_KEY \
      -u ANTHROPIC_AUTH_TOKEN \
      HG_AGENT_SESSION_QUIET=1 \
      "$DOTFILES_DIR/scripts/hg-claude-launch.sh" "$@"
  }

  gemini() {
    HG_AGENT_SESSION_QUIET=1 "$DOTFILES_DIR/scripts/hg-gemini-launch.sh" "$@"
  }

  codex() {
    HG_AGENT_SESSION_QUIET=1 "$DOTFILES_DIR/scripts/hg-codex-launch.sh" "$@"
  }
}

if _hg_agent_session_quiet; then
  _hg_define_agent_wrappers
  return 0 2>/dev/null || exit 0
fi

