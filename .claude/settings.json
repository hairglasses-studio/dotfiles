{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "repo=$(git rev-parse --show-toplevel 2>/dev/null || pwd); bash \"$repo/scripts/claude-phase-gate.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "repo=$(git rev-parse --show-toplevel 2>/dev/null || pwd); bash \"$repo/scripts/claude-phase-gate.sh\"",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "repo=$(git rev-parse --show-toplevel 2>/dev/null || pwd); bash \"$repo/scripts/claude-skill-activate.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "(^Bash$|(^|__)marathon_advance$)",
        "hooks": [
          {
            "type": "command",
            "command": "repo=$(git rev-parse --show-toplevel 2>/dev/null || pwd); bash \"$repo/scripts/claude-marathon-sync.sh\"",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "repo=$(git rev-parse --show-toplevel 2>/dev/null || pwd); bash \"$repo/scripts/claude-phase-gate.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "repo=$(git rev-parse --show-toplevel 2>/dev/null || pwd); bash \"$repo/scripts/claude-phase-gate.sh\"",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "docker": {
      "args": [
        "mcp-server-docker"
      ],
      "command": "uvx"
    },
    "dotfiles": {
      "command": "./scripts/run-dotfiles-mcp.sh"
    }
  }
}
