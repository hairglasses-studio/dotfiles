[Unit]
Description=dotfiles Ironbar top bar
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
Environment=PATH=%h/.local/bin:%h/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/hairglasses-studio/dotfiles/scripts/run-ironbar.sh
Restart=on-failure
RestartSec=2

[Install]
WantedBy=graphical-session.target
