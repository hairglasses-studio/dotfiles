[Unit]
Description=tmux default session
Documentation=man:tmux(1)

[Service]
Type=forking
Environment=PATH=%h/.local/bin:%h/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/bin/tmux new-session -d -s main -c %h/hairglasses-studio
ExecStartPost=-%h/hairglasses-studio/dotfiles/scripts/tmux-persistence-bootstrap.sh --quiet
ExecStop=/usr/bin/tmux kill-server

[Install]
WantedBy=default.target
