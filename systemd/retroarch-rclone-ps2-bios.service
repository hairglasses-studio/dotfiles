[Unit]
Description=RetroArch rclone mount (PS2 BIOS)
After=network-online.target
Wants=network-online.target
PartOf=retroarch-rclone.target

[Service]
Type=simple
Environment=RCLONE_CONFIG=%h/.config/rclone/rclone.conf
ExecStartPre=/usr/bin/bash -lc 'target="%h/Games/RetroArch/mounts/bios/ps2"; mkdir -p "$target"; if mountpoint -q "$target"; then if timeout 5 ls "$target" >/dev/null 2>&1; then exit 0; fi; fusermount3 -uz "$target" 2>/dev/null || umount -l "$target" 2>/dev/null || true; sleep 1; fi; if find "$target" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null | grep -q .; then echo "Refusing to mount over non-empty $target" >&2; exit 1; fi'
ExecStart=/usr/bin/rclone --config %h/.config/rclone/rclone.conf mount "gdrive:Gaming & Emulation/ROMs/bios/ps2" %h/Games/RetroArch/mounts/bios/ps2 --read-only --dir-cache-time 24h --buffer-size 64M --vfs-cache-mode off
ExecStop=/usr/bin/fusermount3 -u %h/Games/RetroArch/mounts/bios/ps2
Restart=on-failure
RestartSec=15
TimeoutStopSec=30
KillMode=mixed

[Install]
WantedBy=retroarch-rclone.target
