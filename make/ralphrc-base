# ralphrc-base — Shared defaults for hairglasses-studio Go projects.
# Source this from your repo's .ralphrc and override as needed:
#   source "$(git rev-parse --show-toplevel)/../../dotfiles/make/ralphrc-base"
#   PROJECT_NAME="my-project"

# ── Project ──────────────────────────────────
PROJECT_TYPE="go"
PROJECT_NAME="unnamed"

# ── Session ──────────────────────────────────
CLAUDE_TIMEOUT_MINUTES=15
SESSION_CONTINUITY="true"
SESSION_EXPIRY_HOURS="24"
CLAUDE_OUTPUT_FORMAT="json"
PRIMARY_MODEL="sonnet"
MAX_CALLS_PER_HOUR=80
RALPH_SESSION_BUDGET="100"

# ── Quality gates ────────────────────────────
QG_GO_BUILD="true"
QG_GO_TEST="true"
QG_GO_VET="true"

# ── Modes ────────────────────────────────────
FAST_MODE_ENABLED="true"
FAST_MODE_DEFAULT="false"
FAST_MODE_PHASES="execution,test,docs,mechanical"
STANDARD_MODE_PHASES="analysis,planning,debug,refactor,architecture"
MARATHON_MODE="true"
MARATHON_DURATION_HOURS="12"
MARATHON_CHECKPOINT_INTERVAL="3"

# ── Batching ─────────────────────────────────
BATCH_SIMILAR_TASKS="true"
MAX_TASKS_PER_BATCH="3"
MAX_LINES_PER_BATCH="600"
LOG_RETENTION_DAYS="7"

# ── Circuit breakers ─────────────────────────
CB_SAME_ERROR_THRESHOLD="5"
CB_NO_PROGRESS_THRESHOLD="4"
CB_COOLDOWN_MINUTES="15"
CB_AUTO_RESET="true"
CB_PERMISSION_DENIAL_THRESHOLD="2"

# ── Cascade ──────────────────────────────────
CASCADE_ENABLED="true"
CASCADE_CHEAP_THRESHOLD="0.4"

# ── Autonomy ─────────────────────────────────
AUTONOMY_LEVEL=1
AUTONOMY_AUTO_RECOVER=true
AUTONOMY_AUTO_RECOVER_MAX=3

# ── Tools ────────────────────────────────────
ALLOWED_TOOLS="Write,Read,Edit,Grep,Glob,Bash(go build *),Bash(go test *),Bash(go vet *),Bash(go run *),Bash(go mod *),Bash(git add *),Bash(git commit *),Bash(git diff *),Bash(git log *),Bash(git status),Bash(git status *),Bash(git push *),Bash(make *)"
