# Catppuccin Mocha delta theme (generated by claudekit)
# Include in .gitconfig: [include] path = ~/.config/delta/catppuccin.gitconfig

[delta]
    syntax-theme = Catppuccin Mocha
    minus-style = syntax #f38ba8
    minus-emph-style = syntax bold #eba0ac
    plus-style = syntax #a6e3a1
    plus-emph-style = syntax bold #94e2d5
    hunk-header-style = syntax bold #89b4fa
    line-numbers-minus-style = #f38ba8
    line-numbers-plus-style = #a6e3a1
    line-numbers-zero-style = #6c7086
