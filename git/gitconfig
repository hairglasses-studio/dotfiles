[user]
    name = hairglasses
    email = mitch@galileo.ai
	signingkey = 54F700788C9F9F1C
[core]
    editor = nvim
    pager = delta
    autocrlf = input
    whitespace = fix
    hooksPath = ~/hairglasses-studio/dotfiles/git/hooks
[include]
    path = ~/.config/delta/snazzy.gitconfig
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    line-numbers = true
    side-by-side = false
[merge]
    conflictstyle = diff3
[diff]
    colorMoved = default
    algorithm = histogram
[fetch]
    prune = true
    prunetags = true
[push]
    default = current
    autoSetupRemote = true
    followTags = true
[pull]
    rebase = true
[rebase]
    autoStash = true
    autoSquash = true
[init]
    defaultBranch = main
[rerere]
    enabled = true
[gpg]
	format = openpgp
[commit]
    gpgsign = true
[alias]
    co = checkout
    cb = checkout -b
    st = status --short --branch
    lg = log --oneline --graph --decorate --all -20
    undo = reset --soft HEAD~1
    wip = !git add -A && git commit -m 'wip [skip ci]'
    cleanup = !git branch --merged main | grep -v 'main' | xargs git branch -d
    pr = !gh pr create --fill
    prc = !gh pr checkout
[url "git@github.com:hairglasses-studio/"]
    insteadOf = hgs:
[url "git@github.com:hairglasses/"]
    insteadOf = hg:
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
