# cava — Cyberpunk Snazzy audio visualizer
# Neon gradient bars with Monstercat-style smoothing
# Cross-platform: PulseAudio (Linux) / portaudio (macOS)

[general]
framerate = 60
autosens = 1
sensitivity = 150
bars = 0
bar_width = 2
bar_spacing = 1
lower_cutoff_freq = 50
higher_cutoff_freq = 10000

[input]
method = pulse
source = auto
; macOS: change method to portaudio
; method = portaudio
; source = auto

[output]
method = ncurses
channels = stereo
mono_option = average

[color]
background = default
foreground = default
gradient = 1
gradient_count = 8
gradient_color_1 = '#29f0ff'
gradient_color_2 = '#7cf7ff'
gradient_color_3 = '#3dffb5'
gradient_color_4 = '#7dffc8'
gradient_color_5 = '#ffe45e'
gradient_color_6 = '#ff47d1'
gradient_color_7 = '#ff84e8'
gradient_color_8 = '#ff5c8a'

[smoothing]
integral = 77
monstercat = 1
waves = 0
gravity = 100
ignore = 0
noise_reduction = 77

[eq]
1 = 1
2 = 1
3 = 1
4 = 1
5 = 1
