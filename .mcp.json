{
  "mcpServers": {
    "sway": {
      "command": "bash",
      "args": ["-c", "export WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-wayland-1}; exec node \"$HOME/hairglasses-studio/sway-mcp/src/index.js\""]
    },
    "hyprland": {
      "command": "bash",
      "args": ["-c", "export WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-wayland-1}; export HYPRLAND_INSTANCE_SIGNATURE=${HYPRLAND_INSTANCE_SIGNATURE:-$(ls /run/user/$(id -u)/hypr/ 2>/dev/null | head -1)}; exec \"$HOME/hairglasses-studio/hyprland-mcp/hyprland-mcp\""]
    },
    "dotfiles": {
      "command": "bash",
      "args": ["-c", "DOTFILES_DIR=\"$HOME/hairglasses-studio/dotfiles\" \"$HOME/hairglasses-studio/dotfiles-mcp/dotfiles-mcp\""]
    },
    "shader": {
      "command": "bash",
      "args": ["-c", "\"$HOME/hairglasses-studio/shader-mcp/shader-mcp\""]
    },
    "input": {
      "command": "bash",
      "args": ["-c", "DOTFILES_DIR=\"$HOME/hairglasses-studio/dotfiles\" \"$HOME/hairglasses-studio/input-mcp/input-mcp\""]
    }
  }
}
