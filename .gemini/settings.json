{
  "context": {
    "fileName": [
      "AGENTS.md",
      "CLAUDE.md",
      "GEMINI.md"
    ]
  },
  "mcp": {
    "allowed": [
      "docker",
      "dotfiles"
    ]
  },
  "mcpServers": {
    "docker": {
      "args": [
        "mcp-server-docker"
      ],
      "command": "uvx"
    },
    "dotfiles": {
      "command": "./scripts/run-dotfiles-mcp.sh"
    }
  }
}
