{
  "context": {
    "fileName": [
      "AGENTS.md",
      "CLAUDE.md",
      "GEMINI.md"
    ]
  },
  "hooks": {
    "AfterTool": [
      {
        "hooks": [
          {
            "command": "./scripts/claude-marathon-sync.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  },
  "mcp": {
    "allowed": [
      "dotfiles"
    ]
  },
  "mcpServers": {
    "dotfiles": {
      "command": "./scripts/run-dotfiles-mcp.sh"
    }
  }
}
